# Stage 1: Build the application using Maven and JDK 25
FROM maven:3-eclipse-temurin-25 AS build
WORKDIR /app
COPY . .
# Use the Maven wrapper provided in your project to build the JAR
RUN ./mvnw clean package -DskipTests

# Stage 2: Run the application
FROM eclipse-temurin:25-jre
WORKDIR /app
# Your pom.xml shows the artifact name is 'dass21'
COPY --from=build /app/target/dass21-0.0.1-SNAPSHOT.jar app.jar
EXPOSE 8080
# Render requires the app to listen on the PORT environment variable
ENTRYPOINT ["java", "-jar", "app.jar", "--server.port=${PORT:8080}"]